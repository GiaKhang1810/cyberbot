    "version": "0.1.0",
    "description": "",
    "keywords": [
        "cyberbot",
        "bot",
        "discord"
    ],
    "homepage": "https://github.com/GiaKhang1810/cyberbot#readme",
    "bugs": {
        "url": "https://github.com/GiaKhang1810/cyberbot/issues"
    },
    "repository": {
        "type": "git",
