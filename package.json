    },
    "license": "SEE LICENSE IN LICENSE.md",
    "author": "Khang",
    "type": "module",
    "main": "source/",
    "scripts": {
        "type": "tsc --noEmit",
        "reset": "rm -rf node_modules bun.lock && bun install",
        "dev:deploy": "bun type && bun source/bin/deploy.ts",
        "dev:clearDeploy": "bun source/bin/clearDeploy.ts",
        "start": "bun type && bun source/index.ts",
        "dev": "bun type && bun --watch source/index.ts"
    },
    "devDependencies": {
        "@discordjs/voice": "^0.19.0",
        "@types/node": "^25.3.5",
        "discord.js": "^14.25.1",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "axios": "^1.13.6",
        "moment-timezone": "^0.6.0"
    }
}